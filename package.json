{
  "name": "gemini-interactive-video-character",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:ensure-agent && npm run dev:web",
    "dev:web": "vite",
    "dev:ensure-agent": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-agent-window.ps1",
    "agent:dev": "npx tsx watch --ignore '.worktrees/**' --ignore 'node_modules/**' --ignore 'src/**' --import ./server/envShim.ts server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "opey:dev": "npx tsx watch --ignore '.worktrees/**' --ignore 'node_modules/**' --ignore 'src/**' --ignore 'agents/**' --import ./server/envShim.ts agents/opey-dev/index.ts",
    "tidy:dev": "npx tsx watch --ignore '.worktrees/**' --ignore 'node_modules/**' --ignore 'src/**' --ignore 'agents/**' --import ./server/envShim.ts agents/tidy/index.ts",
    "whatsapp:dev": "npx tsx --import ./server/envShim.ts whatsapp/index.ts",
    "telegram:dev": "npx tsx watch --ignore '.worktrees/**' --ignore 'node_modules/**' --ignore 'src/**' --import ./server/envShim.ts telegram/index.ts"
  },
  "dependencies": {
    "@ai-sdk/xai": "^2.0.55",
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.78.0",
    "@elevenlabs/elevenlabs-js": "^2.25.0",
    "@google/genai": "^1.33.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.46.1",
    "@whiskeysockets/baileys": "^6.7.8",
    "ai": "^5.0.93",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.41.1",
    "link-preview-js": "^3.2.0",
    "openai": "^6.9.1",
    "pdfjs-dist": "^4.7.76",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^2.1.8",
    "baseline-browser-mapping": "^2.9.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.8"
  }
}
